# Supabase connection strings (from Project → Connect → ORM → Prisma)
# Free tier: both URLs go through the Supavisor pooler (ports 6543 and 5432).
DATABASE_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# Express
PORT=4000

# CORS — frontend dev URL
WEB_ORIGIN=http://localhost:5173

# Dev-mode auth fallback (used until Clerk is wired)
DEV_USER_ID=dev-user-1
DEV_USER_EMAIL=dev@joblog.local
