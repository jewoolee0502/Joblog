{
  "manifest_version": 3,
  "name": "Joblog",
  "version": "1.0.0",
  "description": "Save and track job applications from any job posting page",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://localhost:4000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "externally_connectable": {
    "matches": ["http://localhost:5173/*"]
  }
}
